# Use the Google mirror of Docker Official Images to avoid Docker Hub rate limits
# in CI while keeping the same Debian base image.
FROM mirror.gcr.io/library/debian:stable-slim

RUN apt-get update && \
    apt-get install -y openssh-server openssh-client iproute2 procps sudo && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN ssh-keygen -A

# Create devops user
RUN useradd -m -s /bin/bash devops && \
    echo "devops:devops" | chpasswd

# Setup SSH for devops user
USER devops
RUN mkdir -p /home/devops/.ssh && chmod 700 /home/devops/.ssh
COPY --chown=devops:devops id_ed25519.pub /home/devops/.ssh/authorized_keys
RUN chmod 600 /home/devops/.ssh/authorized_keys

USER root
# Ensure SSH directory exists and has correct permissions
RUN mkdir -p /run/sshd && chmod 755 /run/sshd

# Install pxs (we will mount the binary)
# COPY target/release/pxs /usr/local/bin/pxs

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D", "-e"]
